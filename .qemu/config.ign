  "systemd": {
    "units": [
      {
        "contents": "[Unit]\nDescription=Provisioning System Packages\nAfter=network-online.target\nWants=network-online.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/usr/bin/bash -c ' \\\n  INSTALL_REQUIRED=0; \\\n  for pkg in fastfetch tree; do \\\n    if [ ! -f /usr/bin/$pkg ]; then \\\n      echo \"Package $pkg is missing.\"; \\\n      INSTALL_REQUIRED=1; \\\n      break; \\\n    fi; \\\n  done; \\\n  if [ \"$INSTALL_REQUIRED\" -eq 1 ]; then \\\n    echo \"Starting rpm-ostree installation for: fastfetch tree\"; \\\n    /usr/bin/rpm-ostree install --apply-live --allow-inactive fastfetch tree; \\\n  else \\\n    echo \"Success: All packages (fastfetch tree) are already installed. Skipping.\"; \\\n  fi'\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-system-pkgs.service"
      },
      {
        "contents": "[Unit]\nDescription=Provisioning Starship\nAfter=network-online.target\nConditionPathExists=!/usr/local/bin/starship\n\n[Service]\nType=oneshot\nExecStart=/usr/bin/bash -c ' \\\n  set -eux -o pipefail; \\\n  ARCH=$$(uname -m); \\\n  STARSHIP_VERSION=\"1.24.2\"; \\\n  if [ \"$$ARCH\" == \"x86_64\" ]; then \\\n    STARSHIP_URL=\"https://github.com/starship/starship/releases/download/v$${STARSHIP_VERSION}/starship-x86_64-unknown-linux-gnu.tar.gz\"; \\\n  elif [ \"$$ARCH\" == \"aarch64\" ]; then \\\n    STARSHIP_URL=\"https://github.com/starship/starship/releases/download/v$${STARSHIP_VERSION}/starship-aarch64-unknown-linux-musl.tar.gz\"; \\\n  else exit 1; fi; \\\n  curl --silent --location --fail --remote-name-all --request GET \"$$STARSHIP_URL\" --output /tmp/starship.tar.gz; \\\n  tar --extract --gzip --file /tmp/starship.tar.gz --directory /usr/local/bin; \\\n  rm -rf /tmp/starship.tar.gz'\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-starship.service"
      },
      {
        "contents": "[Unit]\nDescription=Provisioning Lazygit\nAfter=network-online.target\nConditionPathExists=!/usr/local/bin/lazygit\n\n[Service]\nType=oneshot\nExecStart=/usr/bin/bash -c ' \\\n  set -eux -o pipefail; \\\n  ARCH=$$(uname -m); \\\n  LAZYGIT_VERSION=\"0.61.1\"; \\\n  if [ \"$$ARCH\" == \"x86_64\" ]; then \\\n    LAZYGIT_URL=\"https://github.com/jesseduffield/lazygit/releases/download/v$${LAZYGIT_VERSION}/lazygit_$${LAZYGIT_VERSION}_linux_x86_64.tar.gz\"; \\\n  elif [ \"$$ARCH\" == \"aarch64\" ]; then \\\n    LAZYGIT_URL=\"https://github.com/jesseduffield/lazygit/releases/download/v$${LAZYGIT_VERSION}/lazygit_$${LAZYGIT_VERSION}_linux_arm64.tar.gz\"; \\\n  else exit 1; fi; \\\n  curl --silent --location --fail --remote-name-all --request GET \"$$LAZYGIT_URL\" --output /tmp/lazygit.tar.gz; \\\n  tar --extract --gzip --file /tmp/lazygit.tar.gz --directory /usr/local/bin lazygit; \\\n  rm -rf /tmp/lazygit.tar.gz'\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-lazygit.service"
      },
      {
        "contents": "[Unit]\nDescription=Mount Host Shared Directory in Home\nConditionVirtualization=qemu\n\n[Mount]\nWhat=workspace\nWhere=/var/home/tdesaules/workspace\nType=9p\nOptions=trans=virtio,version=9p2000.L,rw,msize=104857600\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "var-home-tdesaules-workspace.mount"
      },
      {
        "contents": "[Unit]\nDescription=Mount Starship Config (ReadOnly)\nConditionVirtualization=qemu\n\n[Mount]\nWhat=starship\nWhere=/etc/starship\nType=9p\nOptions=trans=virtio,version=9p2000.L,ro,msize=104857600\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "etc-starship.mount"
      }
    ]
  }
